# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=kafka-replay-tool
KAFKA_CONSUMER_TIMEOUT_MS=5000
KAFKA_BATCH_SIZE=100

# Database Configuration
DATABASE_URL=postgresql+asyncpg://replay_user:replay_password@localhost:5432/replay_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600

# Logging Configuration
LOG_FORMAT=json
STRUCTLOG_LEVEL=info

# Script Sandbox Configuration
SCRIPT_EXECUTION_TIMEOUT=30
SCRIPT_MAX_MEMORY_MB=256

# Security
SECRET_KEY=your-secret-key-change-in-production
